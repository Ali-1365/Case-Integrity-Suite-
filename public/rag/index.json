  "embeddingDimension": 768,
  "embeddingModel": "text-embedding-004",
  "indexStatus": "PLACEHOLDER_EMBEDDINGS",
  "chunks": [
    {
      "id": "sol_2025_1_1",
      "text": "Samhällets socialtjänst ska på demokratins och solidaritetens grund främja människornas ekonomiska och sociala trygghet, jämlikhet i levnadsvillkor och aktiva deltagande i samhällslivet.",
      "section": 1,
      "chapter": 1,
      "sfsNumber": "2025:400",
      "sourceCode": "SoL",
      "provenanceHash": "sha256-sol2025-1-1",
      "versionChain": [
        "2001:453",
        "2025:400"
      ],
      "embedding": [],
      "metadata": {
        "title": "Socialtjänstlag (2025:400)",
        "validFrom": "2025-07-01",
        "auditStatus": "VERIFIED"
      }
    },
    {
      "id": "sol_2025_1_2",
      "text": "Vid åtgärder som rör barn ska vad som är bäst för barnet vara avgörande. Med barn avses varje människa under 18 år.",
      "section": 2,
      "chapter": 1,
      "sfsNumber": "2025:400",
      "sourceCode": "SoL",
      "provenanceHash": "sha256-sol2025-1-2",
      "versionChain": [
        "2001:453",
        "2025:400"
      ],
      "embedding": [],
      "metadata": {
        "title": "Socialtjänstlag (2025:400)",
        "validFrom": "2025-07-01",
        "auditStatus": "VERIFIED"
      }
    },
    {
      "id": "bk_2018_3",
      "text": "Vid alla åtgärder som rör barn, vare sig de vidtas av offentliga eller privata sociala välfärdsinstitutioner, domstolar, administrativa myndigheter eller lagstiftande organ, ska barnets bästa komma i främsta rummet.",
      "section": 3,
      "sfsNumber": "2018:1197",
      "sourceCode": "BK",
      "provenanceHash": "sha256-bk2018-3",
      "versionChain": [
        "2018:1197"
      ],
      "embedding": [],
      "metadata": {
        "title": "Barnkonventionen (2018:1197)",
        "validFrom": "2020-01-01",
        "auditStatus": "VERIFIED"
      }
    },
    {
      "id": "skl_1972_2_1",
      "text": "Den som uppsåtligen eller av vårdslöshet vållar personskada eller sakskada skall ersätta skadan.",
      "section": 1,
      "chapter": 2,
      "sfsNumber": "1972:207",
      "sourceCode": "SkL",
      "provenanceHash": "sha256-skl1972-2-1",
      "versionChain": [
        "1972:207"
      ],
      "embedding": [],
      "metadata": {
        "title": "Skadeståndslag (1972:207)",
        "validFrom": "1972-07-01",
        "auditStatus": "VERIFIED"
      }
    },
    {
      "id": "skl_1972_3_2",
      "text": "Staten eller en kommun ska ersätta personskada, sakskada eller ren förmögenhetsskada, som vållas genom fel eller försummelse vid myndighetsutövning i verksamhet för vars fullgörande staten eller kommunen svarar.",
      "section": 2,
      "chapter": 3,
      "sfsNumber": "1972:207",
      "sourceCode": "SkL",
      "provenanceHash": "sha256-skl1972-3-2",
      "versionChain": [
        "1972:207"
      ],
      "embedding": [],
      "metadata": {
        "title": "Skadeståndslag (1972:207)",
        "validFrom": "1972-07-01",
        "auditStatus": "VERIFIED"
      }
    },
    {
      "id": "fl_2017_23",
      "text": "En myndighet ska se till att ett ärende blir utrett i den omfattning som dess beskaffenhet kräver. Vid behov ska myndigheten anvisa den enskilde att komplettera ansökan eller anmälan.",
      "section": 23,
      "sfsNumber": "2017:900",
      "sourceCode": "FL",
      "provenanceHash": "sha256-fl2017-23",
      "versionChain": [
        "1986:223",
        "2017:900"
      ],
      "embedding": [],
      "metadata": {
        "title": "Förvaltningslag (2017:900)",
        "validFrom": "2018-07-01",
        "auditStatus": "VERIFIED"
      }
    },
    {
      "id": "sfb_2010_1_1",
      "text": "Denna balk innehåller bestämmelser om social trygghet genom de sociala försäkringar samt andra ersättnings- och bidragssystem som behandlas i avdelningarna B–G (socialförsäkringen).",
      "section": 1,
      "chapter": 1,
      "sfsNumber": "2010:110",
      "sourceCode": "SFB",
      "provenanceHash": "sha256-sfb2010-1-1",
      "versionChain": [
        "2010:110"
      ],
      "embedding": [],
      "metadata": {
        "title": "Socialförsäkringsbalk (2010:110)",
        "validFrom": "2011-01-01",
        "auditStatus": "VERIFIED"
      }
    },
    {
      "id": "lss_1993_7",
      "text": "Personer som anges i 1 § har rätt till insatser i form av särskilt stöd och särskild service enligt 9 § 1–9, om de behöver sådan hjälp i sin livsföring och om deras behov inte tillgodoses på annat sätt.",
      "section": 7,
      "sfsNumber": "1993:387",
      "sourceCode": "LSS",
      "provenanceHash": "sha256-lss1993-7",
      "versionChain": [
        "1993:387"
      ],
      "embedding": [],
      "metadata": {
        "title": "LSS (1993:387)",
        "validFrom": "1994-01-01",
        "auditStatus": "VERIFIED"
      }
    },
    {
      "id": "fb_1949_6_1",
      "text": "Barnets bästa ska vara avgörande vid beslut om vårdnad, boende och umgänge. Vid bedömningen av vad som är bäst för barnet ska det fästas avseende särskilt vid risken för att barnet eller någon annan i familjen utsätts för övergrepp.",
      "section": 1,
      "chapter": 6,
      "sfsNumber": "1949:381",
      "sourceCode": "FB",
      "provenanceHash": "sha256-fb1949-6-1",
      "versionChain": [
        "1949:381"
      ],
      "embedding": [],
      "metadata": {
        "title": "Föräldrabalk (1949:381)",
        "validFrom": "1950-01-01",
        "auditStatus": "VERIFIED"
      }
    },
    {
      "id": "hsl_2017_3_1",
      "text": "Målet med hälso- och sjukvården är en god hälsa och en vård på lika villkor för hela befolkningen. Vården ska ges med respekt för alla människors lika värde och för den enskilda människans värdighet.",
      "section": 1,
      "chapter": 3,
      "sfsNumber": "2017:30",
      "sourceCode": "HSL",
      "provenanceHash": "sha256-hsl2017-3-1",
      "versionChain": [
        "1982:763",
        "2017:30"
      ],
      "embedding": [],
      "metadata": {
        "title": "Hälso- och sjukvårdslag (2017:30)",
        "validFrom": "2017-04-01",
        "auditStatus": "VERIFIED"
      }
    },
    {
      "id": "rb_1942_42_1",
      "text": "Talan om åläggande för svaranden att fullgöra något, talan om fastställelse huruvida visst rättsförhållande består eller icke består, må upptagas, om ovisshet råder om rättsförhållandet och denna länder käranden till förfång.",
      "section": 1,
      "chapter": 42,
      "sfsNumber": "1942:740",
      "sourceCode": "RB",
      "provenanceHash": "sha256-rb1942-42-1",
      "versionChain": [
        "1942:740"
      ],
      "embedding": [],
      "metadata": {
        "title": "Rättegångsbalk (1942:740)",
        "validFrom": "1948-01-01",
        "auditStatus": "VERIFIED"
      }
    },
    {
      "id": "rf_1974_2_1",
      "text": "Den offentliga makten ska utövas med respekt för alla människors lika värde och för den enskilda människans frihet och värdighet.",
      "section": 1,
      "chapter": 2,
      "sfsNumber": "1974:152",
      "sourceCode": "RF",
      "provenanceHash": "sha256-rf1974-2-1",
      "versionChain": [
        "1974:152"
      ],
      "embedding": [],
      "metadata": {
        "title": "Regeringsformen (1974:152)",
        "validFrom": "1974-01-01",
        "auditStatus": "VERIFIED"
      }
    },
