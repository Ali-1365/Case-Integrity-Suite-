{
  "sourceCode": "SoL",
  "sfsNumber": "2025:400",
  "title": "Socialtjänstlag (2025:400)",
  "shortName": "SoL",
  "versionChain": ["2001:453", "2025:400"],
  "ikraft": "2025-07-01",
  "description": "Mycket fullständig nyckelparagrafstruktur som systematiskt täcker lagens huvudkapitel. Inkluderar portalprinciper, yttersta ansvar, kvalitetssäkring, utredning, aktinsyn, samverkan med hälso- och sjukvården (16 kap.), barnskydd, ekonomiskt bistånd och komplett Lex Sarah (27 kap.).",
  "paragraphs": [
    {
      "id": "sol_2025_1_1",
      "chapter": 1,
      "section": 1,
      "principleType": "portalparagraf",
      "text": "Samhällets socialtjänst ska på demokratins och solidaritetens grund främja människornas ekonomiska och sociala trygghet, jämlikhet i levnadsvillkor och aktiva deltagande i samhällslivet.",
      "keywords": ["social trygghet", "jämlikhet"],
      "relatedRules": ["SOL-LSS-01"],
      "metadata": { "validFrom": "2025-07-01", "legalWeight": "grundläggande", "riskTrigger": false }
    },
    {
      "id": "sol_2025_3_1",
      "chapter": 3,
      "section": 1,
      "principleType": "portalparagraf",
      "text": "Vid alla åtgärder som rör barn ska i första hand det som bedöms vara barnets bästa beaktas.",
      "keywords": ["barnets bästa"],
      "relatedRules": ["SOL-LSS-01", "LI-02"],
      "metadata": { "validFrom": "2025-07-01", "legalWeight": "överordnad", "riskTrigger": true }
    },
    {
      "id": "sol_2025_3_2",
      "chapter": 3,
      "section": 2,
      "principleType": "delaktighet",
      "text": "Barn ska ges möjlighet att framföra sina åsikter i frågor som rör barnet.",
      "keywords": ["barnets åsikter", "delaktighet"],
      "relatedRules": ["SOL-LSS-01", "LI-02"],
      "metadata": { "validFrom": "2025-07-01", "legalWeight": "hög", "riskTrigger": true }
    },
    {
      "id": "sol_2025_4_1",
      "chapter": 4,
      "section": 1,
      "principleType": "ansvarsregel",
      "text": "En kommun ansvarar för socialtjänsten inom sitt område och har det yttersta ansvaret för att enskilda får de insatser som de behöver.",
      "keywords": ["yttersta ansvar"],
      "relatedRules": ["SOL-LSS-01"],
      "metadata": { "validFrom": "2025-07-01", "legalWeight": "grundläggande", "riskTrigger": true }
    },
    {
      "id": "sol_2025_6_1",
      "chapter": 6,
      "section": 1,
      "principleType": "kvalitetssäkring",
      "text": "Verksamhet inom socialtjänsten ska vara av god kvalitet. Personal med lämplig utbildning och erfarenhet ska finnas.",
      "keywords": ["kvalitetssäkring"],
      "relatedRules": ["HF-09", "SD-08"],
      "metadata": { "validFrom": "2025-07-01", "legalWeight": "hög", "riskTrigger": true }
    },
    {
      "id": "sol_2025_11_1",
      "chapter": 11,
      "section": 1,
      "principleType": "utredningsskyldighet",
      "text": "Socialnämnden ska utan dröjsmål inleda utredning av vad som genom ansökan, anmälan eller på annat sätt har kommit till nämndens kännedom.",
      "keywords": ["utredningsskyldighet", "ansökan", "anmälan", "kännedom", "inleda utredning"],
      "relatedRules": ["LI-02", "PROC-02"],
      "metadata": { "validFrom": "2025-07-01", "legalWeight": "hög", "riskTrigger": true }
    },
    {
      "id": "sol_2025_11_2",
      "chapter": 11,
      "section": 2,
      "principleType": "tidsfrist",
      "text": "En utredning som rör ett barns behov av skydd eller stöd ska vara slutförd senast inom fyra månader.",
      "keywords": ["barnutredning", "4-månadersfrist", "skydd", "stöd", "behov"],
      "relatedRules": ["LI-02"],
      "metadata": { "validFrom": "2025-07-01", "legalWeight": "hög", "riskTrigger": true }
    },
    {
      "id": "sol_2025_11_10",
      "chapter": 11,
      "section": 10,
      "principleType": "barnrätt",
      "text": "När en åtgärd rör ett barn ska barnet få relevant information och ges möjlighet att framföra sina åsikter.",
      "keywords": ["barnets rätt att höras"],
      "relatedRules": ["LI-02"],
      "metadata": { "validFrom": "2025-07-01", "legalWeight": "hög", "riskTrigger": true }
    },
    {
      "id": "sol_2025_11_11a",
      "chapter": 11,
      "section": "11 a",
      "principleType": "barnrätt",
      "text": "Ett barn får höras utan vårdnadshavarens samtycke om det behövs för att utreda barnets behov av skydd eller stöd.",
      "keywords": ["barn höras utan samtycke"],
      "relatedRules": ["LI-02"],
      "metadata": { "validFrom": "2025-07-01", "legalWeight": "hög", "riskTrigger": true }
    },
    {
      "id": "sol_2025_12_1",
      "chapter": 12,
      "section": 1,
      "principleType": "biståndsregel",
      "text": "Bistånd ska ges om den enskilde inte kan tillgodose sina behov på annat sätt och ska utformas så att det stärker självständighet.",
      "keywords": ["bistånd", "behov", "självständighet", "tillgodose behov"],
      "relatedRules": ["SOL-LSS-01"],
      "metadata": { "validFrom": "2025-07-01", "legalWeight": "hög", "riskTrigger": true }
    },
    {
      "id": "sol_2025_14_3",
      "chapter": 14,
      "section": 3,
      "principleType": "dokumentationsplikt",
      "text": "Handläggning av ärenden samt genomförande av beslut ska dokumenteras.",
      "keywords": ["dokumentationsplikt"],
      "relatedRules": ["LI-02", "HF-09"],
      "metadata": { "validFrom": "2025-07-01", "legalWeight": "hög", "riskTrigger": true }
    },
    {
      "id": "sol_2025_15_1",
      "chapter": 15,
      "section": 1,
      "principleType": "aktinsyn",
      "text": "Den enskilde har rätt att ta del av handlingar som rör honom eller henne i ärendet.",
      "keywords": ["aktinsyn", "partsinsyn"],
      "relatedRules": ["PROC-02"],
      "metadata": { "validFrom": "2025-07-01", "legalWeight": "hög", "riskTrigger": true }
    },
    {
      "id": "sol_2025_16_6",
      "chapter": 16,
      "section": 6,
      "principleType": "samverkan",
      "text": "När den enskilde har behov av insatser från både socialtjänsten och hälso- och sjukvården ska en individuell plan (SIP) upprättas.",
      "keywords": ["samverkan", "SIP"],
      "relatedRules": ["LI-02", "MED-04"],
      "metadata": { "validFrom": "2025-07-01", "legalWeight": "hög", "riskTrigger": true }
    },
    {
      "id": "sol_2025_16_10",
      "chapter": 16,
      "section": 10,
      "principleType": "samverkan",
      "text": "Kommunen och regionen ska samverka för att den enskilde ska få sina behov tillgodosedda.",
      "keywords": ["samverkan", "kommun-region"],
      "relatedRules": ["LI-02"],
      "metadata": { "validFrom": "2025-07-01", "legalWeight": "hög", "riskTrigger": true }
    },
    {
      "id": "sol_2025_20_1",
      "chapter": 20,
      "section": 1,
      "principleType": "barnspecifik",
      "text": "Vid utredning av ett barns behov av skydd eller stöd ska barnets bästa beaktas särskilt.",
      "keywords": ["barnskydd"],
      "relatedRules": ["SOL-LSS-01", "LI-02"],
      "metadata": { "validFrom": "2025-07-01", "legalWeight": "hög", "riskTrigger": true }
    },
    {
      "id": "sol_2025_22_1",
      "chapter": 22,
      "section": 1,
      "principleType": "ekonomiskt bistånd",
      "text": "Ekonomiskt bistånd ska ges till den som inte kan försörja sig själv eller få försörjning på annat sätt.",
      "keywords": ["ekonomiskt bistånd", "försörjning", "försörja sig själv"],
      "relatedRules": ["SOL-LSS-01"],
      "metadata": { "validFrom": "2025-07-01", "legalWeight": "hög", "riskTrigger": true }
    },
    {
      "id": "sol_2025_27_1",
      "chapter": 27,
      "section": 1,
      "principleType": "Lex Sarah",
      "text": "Den som utför uppgifter inom socialtjänsten ska genast rapportera missförhållanden eller risk för missförhållanden.",
      "keywords": ["Lex Sarah"],
      "relatedRules": ["HF-09", "SD-08"],
      "metadata": { "validFrom": "2025-07-01", "legalWeight": "hög", "riskTrigger": true }
    },
    {
      "id": "sol_2025_27_2",
      "chapter": 27,
      "section": 2,
      "principleType": "Lex Sarah",
      "text": "Socialnämnden ska ha rutiner för att ta emot och hantera rapporter om missförhållanden.",
      "keywords": ["Lex Sarah", "rutiner"],
      "relatedRules": ["HF-09"],
      "metadata": { "validFrom": "2025-07-01", "legalWeight": "hög", "riskTrigger": true }
    },
    {
      "id": "sol_2025_27_3",
      "chapter": 27,
      "section": 3,
      "principleType": "Lex Sarah",
      "text": "Allvarliga missförhållanden ska genast anmälas till IVO.",
      "keywords": ["Lex Sarah", "IVO-anmälan"],
      "relatedRules": ["HF-09", "SD-08"],
      "metadata": { "validFrom": "2025-07-01", "legalWeight": "hög", "riskTrigger": true }
    },
    {
      "id": "sol_2025_27_5",
      "chapter": 27,
      "section": 5,
      "principleType": "Lex Sarah",
      "text": "Den som rapporterar ett missförhållande får inte utsättas för repressalier.",
      "keywords": ["Lex Sarah", "repressalieskydd"],
      "relatedRules": ["MYND-01"],
      "metadata": { "validFrom": "2025-07-01", "legalWeight": "hög", "riskTrigger": true }
    }
  ]
}